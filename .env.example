# ============================================
# Backend — save as backend/.env.local
# ============================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/flexist

# Supabase (backend auth verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key

# Platform admin (comma-separated emails)
ADMIN_EMAILS=you@example.com

# OpenAI
OPENAI_API_KEY=sk-...

# Production frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# ============================================
# Frontend — save as frontend/.env.local
# ============================================

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
